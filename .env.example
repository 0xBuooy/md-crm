# Copy to .env and fill in. Loaded automatically by `make test-docker`.
# Never commit a real .env — it is gitignored.

ANTHROPIC_API_KEY=

# Optional — model ID passed to the agent CLIs (default: claude-sonnet-4-6)
# E2E_MODEL=claude-sonnet-4-6

# Optional — filter transcripts by filename substring
# E2E_FILTER=lint

# Optional — override the one-shot invocation for either agent
# HERMES_AGENT_CMD=hermes ask --skill md-crm
# OPENCLAW_AGENT_CMD=openclaw exec --skill md-crm
